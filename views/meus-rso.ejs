<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meus RSO</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<header class="topbar">
  <div class="brand">
    <img src="/logo.png" class="logo-img" onerror="this.outerHTML='<div class=&quot;logo-fallback&quot;>PM</div>'">
    <div>
      <h1>Meus Relatórios</h1>
      <p>Consulta individual de RSO e horas aprovadas</p>
    </div>
  </div>
  <a class="nav-link" href="/">Início</a>
</header>

<main class="page">
  <section class="panel">
    <div class="panel-head">
      <div>
        <span class="badge">MEUS RSO</span>
        <h2><%= user.nome %></h2>
        <p class="muted">Aqui aparecem somente os relatórios enviados pela sua conta.</p>
      </div>
    </div>

    <div class="dashboard">
      <div class="metric">
        <span>Horas aprovadas</span>
        <strong><%= formatarHoras(total) %></strong>
      </div>
      <div class="metric">
        <span>Total de RSO</span>
        <strong><%= relatorios.length %></strong>
      </div>
    </div>

    <% if (relatorios.length === 0) { %>
      <div class="empty">Você ainda não enviou nenhum RSO.</div>
    <% } %>

    <div class="cards">
      <% relatorios.forEach(r => { %>
        <article class="rso-card">
          <div class="rso-top">
            <strong>#<%= r.id %> - <%= r.unidade %></strong>
            <span class="status <%= r.status %>"><%= r.status %></span>
          </div>
          <p><b>Viatura:</b> <%= r.prefixo %></p>
          <p><b>Horário:</b> <%= r.hora_inicio %> até <%= r.hora_saida %></p>
          <p><b>Horas:</b> <%= formatarHoras(r.horas_total) %></p>
          <p class="preview"><%= r.relato.substring(0, 180) %><%= r.relato.length > 180 ? "..." : "" %></p>
        </article>
      <% }) %>
    </div>
  </section>
</main>
</body>
</html>
