<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Cadastro Policial</title><link rel="stylesheet" href="/style.css"></head>
<body>
<header class="topbar">
  <div class="brand">
    <img src="/logo.png" class="logo-img" onerror="this.outerHTML='<div class=&quot;logo-fallback&quot;>PM</div>'">
    <div><h1>Cadastro Policial</h1><p>Crie sua conta para utilizar o sistema RSO</p></div>
  </div>
  <a class="nav-link" href="/">Início</a>
</header>

<main class="hero">
  <section class="hero-card">
    <span class="badge">NOVO ACESSO</span>
    <h2>Criar conta</h2>

    <% if (erro) { %><div class="error"><%= erro %></div><% } %>

    <form class="form-grid" method="POST" action="/cadastro">
      <label class="full">Nome<input name="nome" required placeholder="Ex: Guilherme Marshall"></label>
      <label class="full">Patente<input name="patente" placeholder="Ex: Capitão"></label>
      <label class="full">Senha<input name="senha" type="password" required placeholder="Crie uma senha"></label>
      <button class="btn-primary full" type="submit">Cadastrar</button>
    </form>

    <p class="muted" style="margin-top:18px;">Já tem conta?</p>
    <a class="btn-secondary" href="/login">Entrar</a>
  </section>
</main>
</body>
</html>
