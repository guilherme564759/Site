<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Manager</title><link rel="stylesheet" href="/style.css"></head><body><header class="topbar"><div class="brand"><div class="logo">PM</div><div><h1>Polícia Militar do Estado de São Paulo - SSP</h1><p>Acesso Manager</p></div></div><a class="nav-link" href="/">Início</a></header><main class="center-page"><section class="panel login"><h2>Manager</h2><p class="muted">Entre para analisar, aprovar e gerenciar relatórios.</p><% if (erro) { %><div class="danger"><%= erro %></div><% } %><form method="POST" action="/manager/login" class="stack"><label>Usuário<input name="nome" required placeholder="Administrador"></label><label>Senha<input name="senha" type="password" required placeholder="admin123"></label><button class="btn-primary" type="submit">Entrar</button></form></section></main></body></html>