<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Manager</title><link rel="stylesheet" href="/style.css"></head><body><header class="topbar"><div class="brand"><img src="/logo.png" class="logo-img" onerror="this.outerHTML='<div class=&quot;logo-fallback&quot;>PM</div>'"><div><h1>Acesso Manager</h1><p>Painel administrativo do RSO</p></div></div><a class="nav-link" href="/">Início</a></header><main class="hero"><section class="hero-card"><span class="badge">MANAGER</span><h2>Entrar no painel</h2><% if (erro) { %><div class="error"><%= erro %></div><% } %><form class="form-grid" method="POST" action="/manager/login"><label class="full">Usuário<input name="nome" required placeholder="Administrador"></label><label class="full">Senha<input name="senha" type="password" required placeholder="admin123"></label><button class="btn-primary full" type="submit">Entrar</button></form></section></main></body></html>