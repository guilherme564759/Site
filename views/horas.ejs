<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Horas Aprovadas</title><link rel="stylesheet" href="/style.css"></head>
<body>
<header class="topbar">
  <div class="brand">
    <img src="/logo.png" class="logo-img" onerror="this.outerHTML='<div class=&quot;logo-fallback&quot;>PM</div>'">
    <div><h1>Horas Aprovadas</h1><p>Somatório por responsável pelo envio</p></div>
  </div>
  <a class="nav-link" href="/manager">Voltar</a>
</header>

<main class="page">
  <section class="panel">
    <div class="panel-head">
      <div><span class="badge">CONTROLE DE HORAS</span><h2>Horas por policial</h2></div>
    </div>

    <% if (usuarios.length === 0) { %><div class="empty">Nenhuma hora aprovada ainda.</div><% } %>

    <div class="table-list">
      <% usuarios.forEach(u => { %>
        <div class="user-row">
          <strong><%= u.nome_envio %></strong>
          <span><%= u.total_rso %> RSO aprovado(s)</span>
          <span><%= formatarHoras(u.total_horas) %></span>
        </div>
      <% }) %>
    </div>
  </section>
</main>
</body>
</html>
