<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Horas</title><link rel="stylesheet" href="/style.css"></head><body><header class="topbar"><div class="brand"><img src="/logo.png" class="logo-img" onerror="this.outerHTML='<div class=&quot;logo-fallback&quot;>PM</div>'"><div><h1>Controle de Horas</h1><p>Busca por policial participante</p></div></div><a class="nav-link" href="/manager">Voltar</a></header><main class="page"><section class="panel"><span class="badge">HORAS POR POLICIAL</span><h2>Consulta de horas</h2><form class="filter-grid" method="GET" action="/manager/horas"><label>Nome do policial<input name="policial" value="<%= policial %>" placeholder="Digite o nome"></label><button class="btn-primary" type="submit">Consultar</button></form><% if (selecionado) { %><div class="dashboard"><div class="metric"><span>Policial</span><strong><%= selecionado.nome %></strong></div><div class="metric"><span>Horas aprovadas</span><strong><%= formatarHoras(selecionado.total_horas) %></strong></div><div class="metric"><span>Aprovados</span><strong><%= selecionado.aprovados %></strong></div><div class="metric"><span>Pendentes</span><strong><%= selecionado.pendentes %></strong></div><div class="metric"><span>Recusados</span><strong><%= selecionado.recusados %></strong></div></div><% } %><h3>Ranking geral</h3><div class="table-list"><% usuarios.forEach(u => { %><div class="user-row"><strong><%= u.nome %></strong><span><%= u.total_rso %> RSO(s)</span><span><%= formatarHoras(u.total_horas) %></span><a class="btn-secondary" href="/manager/horas?policial=<%= encodeURIComponent(u.nome) %>">Ver</a></div><% }) %></div></section></main></body></html>