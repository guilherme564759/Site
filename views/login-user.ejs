<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Login Policial</title><link rel="stylesheet" href="/style.css"></head>
<body>
<header class="topbar">
  <div class="brand">
    <img src="/logo.png" class="logo-img" onerror="this.outerHTML='<div class=&quot;logo-fallback&quot;>PM</div>'">
    <div><h1>Login Policial</h1><p>Acesse sua conta para enviar e consultar seus RSO</p></div>
  </div>
  <a class="nav-link" href="/">Início</a>
</header>

<main class="hero">
  <section class="hero-card">
    <span class="badge">ACESSO POLICIAL</span>
    <h2>Entrar</h2>

    <% if (erro) { %><div class="error"><%= erro %></div><% } %>

    <form class="form-grid" method="POST" action="/login">
      <label class="full">Nome<input name="nome" required placeholder="Seu nome de acesso"></label>
      <label class="full">Senha<input name="senha" type="password" required placeholder="Sua senha"></label>
      <button class="btn-primary full" type="submit">Entrar</button>
    </form>

    <p class="muted" style="margin-top:18px;">Ainda não tem conta?</p>
    <a class="btn-secondary" href="/cadastro">Criar cadastro</a>
  </section>
</main>
</body>
</html>
