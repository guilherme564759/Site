<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Permissões</title><link rel="stylesheet" href="/style.css"></head>
<body>
<header class="topbar">
  <div class="brand">
    <img src="/logo.png" class="logo-img" onerror="this.outerHTML='<div class=&quot;logo-fallback&quot;>PM</div>'">
    <div><h1>Permissões Manager</h1><p>Cadastre pessoas autorizadas a aprovar RSO</p></div>
  </div>
  <a class="nav-link" href="/manager">Voltar</a>
</header>

<main class="page">
  <section class="panel">
    <div class="panel-head">
      <div><span class="badge">ACESSOS</span><h2>Adicionar permissão</h2></div>
    </div>

    <form method="POST" action="/manager/permissoes" class="form-grid">
      <label>Nome de acesso<input name="nome" required placeholder="Ex: Corregedoria"></label>
      <label>Senha<input name="senha" required placeholder="Crie uma senha"></label>
      <button class="btn-primary full" type="submit">Adicionar permissão</button>
    </form>

    <div class="cards">
      <% permissoes.forEach(p => { %>
        <article class="rso-card">
          <div class="rso-top"><strong><%= p.nome %></strong><span class="badge">Manager</span></div>
          <p>Criado em: <%= p.criado_em %></p>
          <form method="POST" action="/manager/permissoes/<%= p.id %>/remover">
            <button class="btn-deny" type="submit">Remover</button>
          </form>
        </article>
      <% }) %>
    </div>
  </section>
</main>
</body>
</html>
