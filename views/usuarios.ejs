<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Usuários Discord</title><link rel="stylesheet" href="/style.css"></head><body><header class="topbar"><div class="brand"><img src="/logo.png" class="logo-img" onerror="this.outerHTML='<div class=&quot;logo-fallback&quot;>PM</div>'"><div><h1>Usuários Discord</h1><p>Sincronize membros do servidor e gerencie seus dados</p></div></div><a class="nav-link" href="/manager">Voltar</a></header><main class="page"><section class="panel"><span class="badge">DISCORD / MEMBROS</span><h2>Sincronizar membros do servidor</h2><p class="muted">Use o botão para puxar nomes e avatares dos membros do Discord configurado.</p><form method="POST" action="/manager/usuarios/sync"><button class="btn-discord" type="submit">Sincronizar Discord</button></form><% if (sync && sync.ok) { %><div class="success">✅ Sincronização concluída. Membros sincronizados: <%= sync.total %></div><% } %><% if (erro) { %><div class="error"><%= erro %></div><% } %><form class="filter-grid" method="GET" action="/manager/usuarios"><label>Buscar<input name="busca" value="<%= busca %>" placeholder="Nome, usuário, patente ou unidade"></label><button class="btn-primary" type="submit">Buscar</button></form><div class="cards"><% usuarios.forEach(u => { %><article class="rso-card"><div class="rso-top"><div style="display:flex;align-items:center;gap:12px;"><% if (u.avatar) { %><img src="<%= u.avatar %>" class="avatar"><% } %><strong><%= u.nome %></strong></div><span class="status <%= u.ativo ? 'aprovado' : 'recusado' %>"><%= u.ativo ? 'ativo' : 'inativo' %></span></div><p><b>Discord:</b> <%= u.discord_username || 'Não informado' %></p><form class="form-grid" method="POST" action="/manager/usuarios/<%= u.id %>/editar"><label>Patente<input name="patente" value="<%= u.patente || '' %>" placeholder="Ex: Cabo"></label><label>Unidade<select name="unidade"><option value="">Selecione</option><% unidades.forEach(un => { %><option <%= u.unidade===un?'selected':'' %>><%= un %></option><% }) %></select></label><button class="btn-primary full" type="submit">Salvar dados</button></form><form method="POST" action="/manager/usuarios/<%= u.id %>/status" style="margin-top:12px;"><button class="<%= u.ativo ? 'btn-deny' : 'btn-approve' %>" type="submit"><%= u.ativo ? 'Desativar' : 'Ativar' %></button></form></article><% }) %></div></section></main></body></html>