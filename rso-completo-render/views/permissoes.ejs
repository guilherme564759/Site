<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RSO - PMESP</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<header class="topbar">
  <div class="brand">
    <div class="logo">PM</div>
    <div>
      <h1>Permissões Manager</h1>
      <p>Cadastre pessoas autorizadas a aprovar RSO</p>
    </div>
  </div>
  <a class="nav-link" href="/manager">Voltar</a>
</header>

<main class="page">
  <section class="panel wide">
    <h2>Adicionar Permissão</h2>

    <form method="POST" action="/manager/permissoes" class="form-grid small">
      <label>
        Nome de acesso
        <input name="nome" required placeholder="Ex: Corregedoria">
      </label>

      <label>
        Senha
        <input name="senha" required placeholder="Crie uma senha">
      </label>

      <button class="btn-primary" type="submit">Adicionar</button>
    </form>

    <h2 class="mt">Usuários autorizados</h2>

    <div class="cards">
      <% permissoes.forEach(p => { %>
        <article class="rso-card">
          <strong><%= p.nome %></strong>
          <p>Criado em: <%= p.criado_em %></p>
          <form method="POST" action="/manager/permissoes/<%= p.id %>/remover">
            <button class="btn-deny small-btn" type="submit">Remover</button>
          </form>
        </article>
      <% }) %>
    </div>
  </section>
</main>

</body>
</html>
